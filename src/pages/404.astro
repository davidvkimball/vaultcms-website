---
import Layout from "../layouts/Layout.astro";
import { ArrowLeft } from "lucide-react";
---

<Layout title="Page not found - Vault CMS" description="The page you're looking for doesn't exist.">
  <div class="min-h-screen bg-background selection:bg-primary/20 selection:text-primary flex flex-col">
    <div class="max-w-2xl mx-auto px-6 sm:px-8 w-full flex-1 flex flex-col items-center justify-center text-center">
      <h1 class="font-heading text-6xl sm:text-8xl font-bold text-muted-foreground/50">404</h1>
      <p class="mt-4 text-lg text-muted-foreground">
        The page you're looking for doesn't exist.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gradient-to-r from-primary to-secondary text-white font-heading font-medium transition-all shadow-md hover:shadow-primary/20 active:scale-95 group"
      >
        <ArrowLeft className="w-5 h-5 transition-transform group-hover:-translate-x-1" />
        Back to home
      </a>
    </div>
  </div>
</Layout>
